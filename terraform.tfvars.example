# ==============================================================
# Copier ce fichier en terraform.tfvars et adapter les valeurs.
# Ne pas commiter terraform.tfvars si il contient des secrets.
# ==============================================================

# ==============================================================
# GÉNÉRAL
# ==============================================================
aws_region        = "eu-west-1"
aws_access_key    = "votre-access_key"
aws_secret_key    = "votre-access_secret_key"
project           = "isi_project"
environment       = "dev"
availability_zone = "eu-west-1a"

# ==============================================================
# RÉSEAU
# ==============================================================
vpc_cidr_block        = "10.0.0.0/16"
subnet_pub_cidr_block = "10.0.1.0/24"
subnet_priv_cidr_block = "10.0.2.0/24"

# ==============================================================
# SÉCURITÉ - Restreindre en prod (ex: "VOTRE_IP/32")
# ==============================================================
allowed_ssh_cidr = "0.0.0.0/0"
public_key_path  = "~/.ssh/id_rsa.pub"

# ==============================================================
# AMI (par défaut Ubuntu 22.04 LTS)
# ==============================================================
# ami_owner      = "099720109477"
# ami_name_filter = "ubuntu/images/hvm-ssd/ubuntu-jammy-22.04-amd64-server-*"

# ==============================================================
# EC2
# ==============================================================
instance_type    = "t2.micro"
root_volume_size = 80
root_volume_type = "gp2"
instance_user_data_message = "Hello from ISI Public Instance"
